# Environment variables — copy to .env and fill in values
# Never commit .env to version control

# Supabase — server
SUPABASE_URL=                  # e.g. https://xxxx.supabase.co
SUPABASE_ANON_KEY=             # safe for client-side use
SUPABASE_SERVICE_KEY=          # SERVER ONLY — never expose to client or browser

# Supabase — client (Vite exposes only VITE_ prefixed vars to the browser)
VITE_SUPABASE_URL=             # same value as SUPABASE_URL
VITE_SUPABASE_ANON_KEY=        # same value as SUPABASE_ANON_KEY

# Anthropic (server only)
ANTHROPIC_API_KEY=             # SERVER ONLY

# Apify (server only)
APIFY_API_KEY=                 # SERVER ONLY
APIFY_API_TOKEN=               # SERVER ONLY — same value as APIFY_API_KEY (alias used in some contexts)

# Replicate (server only — used for Whisper transcription)
REPLICATE_API_TOKEN=           # SERVER ONLY

# CORS — set to exact frontend origin (no trailing slash)
CORS_ORIGIN=http://localhost:5173  # use https://reeleats.app in production

# Session
SESSION_SECRET=                # random 64-char string — generate with: openssl rand -hex 32

# Runtime
PORT=3000                      # server listen port (Railway sets this automatically)
NODE_ENV=development           # set to "production" in Railway/Vercel
